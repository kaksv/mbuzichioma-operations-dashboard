# Admin API origin (no trailing slash), e.g. https://mbuzzi-api.onrender.com
VITE_API_BASE_URL=

# Optional admin key for /api/admin/* routes (must match API ADMIN_API_KEY)
VITE_ADMIN_API_KEY=

# Optional Cloudinary delivery fallback in the browser
# VITE_CLOUDINARY_CLOUD_NAME=
# VITE_CLOUDINARY_IMAGE_TRANSFORM=f_auto,q_auto
